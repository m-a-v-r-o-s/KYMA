# Copy this file to .env.local to configure the site.

# The owner dashboard lives at /admin
NEXT_PUBLIC_ADMIN_PASSWORD=kyma2025

# Stripe — required for instant "Book & pay" checkout.
# Get your secret key at https://dashboard.stripe.com/apikeys
# Use a test key (sk_test_...) while developing.
# If this is unset, the booking form still works via "Request to book".
STRIPE_SECRET_KEY=sk_test_xxx
